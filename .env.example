# Smartal User Frontend - Environment Variables
# Copy this file to .env.development for local development

# Backend API base URL (required in production)
VITE_API_BASE_URL=https://api.smartal.net/api
# Asset base URL - used for legacy /uploads image paths (Cloudinary URLs are used as-is)
VITE_ASSET_BASE_URL=https://api.smartal.net
